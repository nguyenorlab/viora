# Frontend -> same-origin Vercel Function.
VITE_ATTENDANCE_API_BASE_URL=/api/attendance

# Optional legacy token fallback. New login flow does not require this on frontend.
# Leave empty in production if you only use username/password login.
VITE_ADMIN_ACCESS_TOKEN=

# Server-side only. Do NOT prefix these with VITE_.
GOOGLE_SPREADSHEET_ID=your-google-sheet-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"

# Backend session and bootstrap super admin.
SESSION_SECRET=change-this-long-random-session-secret
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change-this-super-admin-password

# Optional legacy API token. Also used as fallback SESSION_SECRET if SESSION_SECRET is empty.
ADMIN_API_TOKEN=change-this-legacy-admin-token

# Local dev default. For production use your domain, e.g. https://www.viora.vn
ADMIN_ALLOWED_ORIGIN=http://localhost:3000

# Optional quota tuning for Google Sheets API reads.
SHEETS_SCHEMA_CACHE_MS=300000
SHEETS_READ_CACHE_MS=20000
